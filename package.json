{
  "name": "btp-iflow-manager",
  "version": "1.0.0",
  "private": true,
  "proxy": "http://localhost:3001",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "lucide-react": "^0.383.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && npm run copy:approuter",
    "copy:approuter": "rimraf approuter/resources && mkdir -p approuter/resources && cp -r build/. approuter/resources/",
    "start:proxy": "cd proxy && node server.js",
    "dev": "concurrently \"npm start\" \"npm run start:proxy\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
