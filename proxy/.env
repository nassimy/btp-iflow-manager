# ─────────────────────────────────────────────────────────────────────────────
# BTP Integration Suite — Proxy Credentials
# Copy this file to .env and fill in your values from the BTP service key.
#
# HOW TO GET THESE VALUES:
#   BTP Cockpit → Subaccount → Services → Instances
#   → Open your "Process Integration Runtime" instance (plan: api)
#   → Service Keys → View your service key JSON
#
# The JSON from BTP looks like this:
#   {
#     "clientid":     "sb-xxxxxxxx!xxx",          → BTP_CLIENT_ID
#     "clientsecret": "xxxxxxxx-xxxx-xxxx",        → BTP_CLIENT_SECRET
#     "url":          "https://xxx.auth.eu10...",  → BTP_TOKEN_URL
#     "baseurl":      "https://xxx.cfapps.eu10..."  → BTP_BASE_URL
#   }
# ─────────────────────────────────────────────────────────────────────────────

# Your tenant's runtime base URL (from "baseurl" in the service key)
BTP_BASE_URL=https://<your-tenant>.it-cpi018-rt.cfapps.eu10.hana.ondemand.com

# OAuth token endpoint (from "url" in the service key — do NOT include /oauth/token)
BTP_TOKEN_URL=https://<your-tenant>.authentication.eu10.hana.ondemand.com

# OAuth client credentials (from "clientid" and "clientsecret" in the service key)
BTP_CLIENT_ID=sb-xxxxxxxx!xxxxxxx
BTP_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Port this proxy listens on (default: 3001, no need to change)
PORT=3001
